{
  "name": "drift",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p tsconfig.e2e.json",
    "lint": "eslint src e2e playwright.config.ts",
    "format": "prettier --write src e2e playwright.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "build:icons": "inkscape public/icons/icon.svg --export-type=png -w 192 -h 192 -o public/icons/icon-192.png && inkscape public/icons/icon.svg --export-type=png -w 512 -h 512 -o public/icons/icon-512.png"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "melt": "^0.44.0"
  }
}
